# Copier ce fichier en ".env" (à la racine, à côté de docker-compose.yml)
# et renseigner la vraie clé. Le fichier ".env" ne doit jamais être committé.

QWEN_API_KEY=sk-votre-cle-ici
# Endpoint international (compte Qwen Cloud hors Chine continentale).
# Pour un compte Chine continentale : https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Optionnel : override des modèles utilisés par QwenClient
# QWEN_MODEL_FAST=qwen3.6-flash
# QWEN_MODEL_REASONING=qwen3.7-max
# QWEN_MODEL_VL=qwen3-vl-flash
# QWEN_MODEL_ASR=qwen3-asr-flash

# Base de données (valeurs par défaut déjà utilisées par docker-compose.yml)
DB_NAME=mboaops
DB_USER=mboaops
DB_PASSWORD=mboaops
